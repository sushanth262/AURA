{
  "expo": {
    "name": "AURA",
    "slug": "aura-frontend",
    "version": "0.1.0",
    "orientation": "default",
    "icon": "./icons/Aura_logo_cropped.png",
    "scheme": "aura",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./icons/Aura_logo_cropped.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2B65"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aura.frontend"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icons/Aura_logo_cropped.png",
        "backgroundColor": "#1B2B65"
      },
      "package": "com.aura.frontend"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./icons/Aura_logo_cropped.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B2B65",
          "image": "./icons/Aura_logo_cropped.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
